From fab0ff13b2e9405a3daeb4778c513a114ac1e9c5 Mon Sep 17 00:00:00 2001
From: Huiwen He <hehuiwen@kylinos.cn>
Date: Wed, 15 Jul 2026 22:32:56 +0800
Subject: [PATCH] smb/client: flush dirty data before zeroing a range

Before this change, smb3_zero_range() only flushed dirty data when
the target range reached the server-side EOF. Otherwise,
truncate_pagecache_range() could discard dirty folios before
FSCTL_SET_ZERO_DATA was sent. If the request failed, the discarded
data could not be recovered.

Fix this by flushing the target range up to the local EOF before
invalidating the page cache, regardless of remote_i_size.

Reproduce this by temporarily forcing smb3_zero_data() to return
-EIO for a 1 MiB zero range:

  xfs_io -f -c "pwrite -S 0x41 0 8m" -c fsync $file
  echo 3 > /proc/sys/vm/drop_caches
  xfs_io -c "pwrite -S 0x42 1m 4k" \
         -c "fzero 1m 1m" $file
  echo 3 > /proc/sys/vm/drop_caches
  xfs_io -c "pread -v 1m 16" $file

The old code lost the completed 0x42 buffered write, while the fixed
code preserved it.

Fixes: 6b69040247e1 ("cifs/smb3: Fix data inconsistent when zero file range")
Signed-off-by: Huiwen He <hehuiwen@kylinos.cn>
---
 fs/smb/client/smb2ops.c | 10 +++++++---
 1 file changed, 7 insertions(+), 3 deletions(-)

diff --git a/fs/smb/client/smb2ops.c b/fs/smb/client/smb2ops.c
index cbd51a08e97e..c38f40cacd33 100644
--- a/fs/smb/client/smb2ops.c
+++ b/fs/smb/client/smb2ops.c
@@ -3433,7 +3433,7 @@ static long smb3_zero_range(struct file *file, struct cifs_tcon *tcon,
 	struct inode *inode = file_inode(file);
 	struct cifsInodeInfo *cifsi = CIFS_I(inode);
 	struct cifsFileInfo *cfile = file->private_data;
-	unsigned long long i_size, new_size, remote_i_size, zero_point;
+	unsigned long long i_size, new_size;
 	long rc;
 	unsigned int xid;
 
@@ -3444,8 +3444,12 @@ static long smb3_zero_range(struct file *file, struct cifs_tcon *tcon,
 
 	filemap_invalidate_lock(inode->i_mapping);
 
-	netfs_read_sizes(inode, &i_size, &remote_i_size, &zero_point);
-	if (offset + len >= remote_i_size && offset < i_size) {
+	/*
+	 * Flush dirty data before invalidating the target range so that it is
+	 * not lost if the server-side zeroing fails.
+	 */
+	i_size = i_size_read(inode);
+	if (offset < i_size) {
 		unsigned long long top = umin(offset + len, i_size);
 
 		rc = filemap_write_and_wait_range(inode->i_mapping, offset, top - 1);
-- 
2.43.0

